# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgres://neo:neo_secret@localhost:5432/neo_domotique

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# S3/MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=neo_minio
S3_SECRET_KEY=neo_minio_secret
S3_BUCKET_PHOTOS=neo-photos
S3_BUCKET_DOCUMENTS=neo-documents
S3_REGION=us-east-1

# Admin
ADMIN_EMAIL=admin@neo.fr
ADMIN_PASSWORD=admin123
